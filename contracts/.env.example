# Copy to contracts/.env and fill in before deploying.

# Private key of the deployer wallet (no 0x prefix required but allowed).
# Fund it from the Conflux eSpace testnet faucet: https://efaucet.confluxnetwork.org
DEPLOYER_PRIVATE_KEY=

# Optional RPC overrides (defaults are the public Conflux RPCs).
CONFLUX_ESPACE_RPC=https://evm.confluxrpc.com
CONFLUX_ESPACE_TESTNET_RPC=https://evmtestnet.confluxrpc.com

# Optional: a ConfluxScan API key so `pnpm deploy:testnet` can auto-verify the contract.
# Get one at https://evmtestnet.confluxscan.io/.
CONFLUXSCAN_API_KEY=

# Set to "true" to print gas reports when running tests.
REPORT_GAS=false

# Optional: skip deploying the TestERC20 USDT0/AxCNH mocks even on testnets.
SKIP_MOCK_TOKENS=false
