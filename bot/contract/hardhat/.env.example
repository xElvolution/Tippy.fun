# 64 hex secp256k1 private key (same format as Tippy custodial vault: no 0x or with 0x)
CONTRACT_DEPLOYER_PRIVATE_KEY=

# Optional: MasterTip admin (defaults to deployer)
# MASTER_TIP_ADMIN=0x...

# Optional: initial TestUSDT balance recipient (defaults to deployer)
# TEST_USDT_RECIPIENT=0x...

# Optional RPC overrides
# CONFLUX_TESTNET_RPC_URL=https://evmtestnet.confluxrpc.com
# CONFLUX_MAINNET_RPC_URL=https://evm.confluxrpc.com
