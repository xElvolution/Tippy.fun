{
  "name": "tippy",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:bot": "tsx watch bot/index.ts",
    "register-commands": "tsx bot/registerCommandsCli.ts",
    "clear-global-commands": "tsx bot/clearGlobalCommandsCli.ts",
    "dump-slash-payload": "tsx -e \"import { writeFileSync } from 'fs'; import { commandData } from './bot/registerCommands.ts'; writeFileSync('lib/discord/slashCommandsPayload.json', JSON.stringify(commandData));\"",
    "dev:all": "concurrently -n web,bot -c blue,magenta \"pnpm dev\" \"pnpm dev:bot\"",
    "build": "next build",
    "start": "next start --port 3000",
    "start:bot": "tsx bot/index.ts",
    "lint": "next lint",
    "contracts:install": "pnpm install --dir contract/hardhat",
    "contracts:compile": "pnpm --dir contract/hardhat exec hardhat compile",
    "deploy:contracts": "pnpm --dir contract/hardhat exec hardhat run scripts/deploy.ts --network confluxESpaceTestnet"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "14.2.35",
    "next-auth": "4.24.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2"
  }
}
