# --- Supabase (Postgres) ---
# Project URL: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Server + bot only - never commit or expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Optional: browser client later (with RLS policies)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional alias if you prefer not to use NEXT_PUBLIC_ for server-only scripts
# SUPABASE_URL=https://xxxx.supabase.co

# AES-256-GCM key for custodial private keys (32 bytes = 64 hex chars)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Conflux eSpace: testnet | mainnet (chain IDs 71 / 1030)
CONFLUX_NETWORK=testnet
# Match CONFLUX_NETWORK for client-only links (landing footer, sidebar explorer URL)
NEXT_PUBLIC_CONFLUX_NETWORK=testnet

# MasterTip Solidity contract (guild point requests on-chain). Deploy via contract/hardhat.
# MASTER_TIP_CONTRACT=0x...

# Optional ERC-20 for dashboard + /tip autocomplete. Use deployed TestUSDT from contract/hardhat
# TEST_ERC20_CONTRACT=0x...
# TEST_ERC20_DECIMALS=6

# Deploy contracts (Hardhat): same 64-hex key as Tippy wallets; never commit real keys.
# CONTRACT_DEPLOYER_PRIVATE_KEY=

# Optional public links (override defaults: Conflux Scan, Conflux Discord/X, docs)
# NEXT_PUBLIC_EXPLORER_URL=
# NEXT_PUBLIC_COMMUNITY_DISCORD_URL=
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_LEARN_URL=

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# OAuth2 Client Secret - required for web “Log in with Discord” (NextAuth). Not the bot token.
DISCORD_CLIENT_SECRET=
# Optional: owner console / docs only. Slash commands are global; bot clears per-guild copies on every server it’s in.
DISCORD_GUILD_ID=

# NextAuth (Discord provider) - generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Optional: log NextAuth errors to terminal (OAuthCallback debugging)
# NEXTAUTH_DEBUG=true

# Same Application ID as DISCORD_CLIENT_ID - public; powers the site “Add to Discord” button
NEXT_PUBLIC_DISCORD_CLIENT_ID=
# Optional: full OAuth URL (overrides NEXT_PUBLIC_DISCORD_CLIENT_ID if set)
# NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.com/oauth2/authorize?client_id=...&permissions=2147568640&scope=bot%20applications.commands

# Site origin only (no path). Bot `/wallet` uses this; optional deep links: /?view=activity | console | help | settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
